rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }

    // Validation for Inquiry
    function isValidInquiry(data) {
      return data.keys().hasAll(['id', 'customer', 'items', 'timestamp', 'status']) 
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 50
        && data.customer is map
        && data.customer.name is string && data.customer.name.size() <= 100
        && data.customer.email is string && data.customer.email.size() <= 100
        && data.customer.company is string && data.customer.company.size() <= 100
        && data.items is list
        && data.status in ['pending', 'reviewed', 'resolved']
        && data.timestamp is string; // Since we are using ISO string client-side for consistency with previous logic
    }

    match /inquiries/{inquiryId} {
      // Allow anyone to submit an inquiry
      allow create: if isValidInquiry(incoming());
      
      // Allow reading for management (simple for now since we don't have secondary auth set up yet)
      // In production, this should be restricted to authenticated admins
      allow read: if true; 
      
      // No updates or deletes from the client for now to keep data integrity
      allow update, delete: if false;
    }
  }
}
